require 'dotenv'
Dotenv.load

default_platform(:android)

def resolved_android_version_code
  raw = ENV["ANDROID_VERSION_CODE"] || ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
  code = raw.to_i

  if code <= 0 || raw.to_s !~ /\A\d+\z/
    UI.user_error!("Invalid Android version code '#{raw}'. Set ANDROID_VERSION_CODE (positive integer).")
  end

  UI.important("Using Android version code: #{code}")
  code
end

def resolved_version_label
  raw = ENV["VERSION_LABEL"]&.strip
  value = raw.nil? || raw.empty? ? "1.1.17" : raw

  unless value.match?(/\A\d+\.\d+\.\d+\z/)
    UI.user_error!("Invalid version label '#{value}'. Use semantic format like 1.1.17.")
  end

  UI.important("Using version label: #{value}")
  value
end

def resolved_ios_build_number
  raw = ENV["IOS_BUILD_NUMBER"] || ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
  value = raw.to_i

  if value <= 0 || raw.to_s !~ /\A\d+\z/
    UI.user_error!("Invalid iOS build number '#{raw}'. Set IOS_BUILD_NUMBER (positive integer).")
  end

  UI.important("Using iOS build number: #{value}")
  value
end

def resolved_ios_team_id
  ENV["IOS_TEAM_ID"] || "Y6YJ4P25H9"
end

def resolved_ios_profile_name
  raw = ENV["IOS_PROFILE_NAME"]&.strip
  raw.nil? || raw.empty? ? "carplay" : raw
end

def prepare_build_dirs
  sh "mkdir -p build/android"
  sh "mkdir -p build/ios"
end

platform :android do
  desc "Build Android and upload to Play Closed Testing"
  lane :ci_android do
    prepare_build_dirs

    gradle(
      tasks: ["clean", "assembleRelease", "bundleRelease"],
      project_dir: "android",
      flags: "--no-daemon",
      properties: {
        "android.injected.version.code" => resolved_android_version_code,
        "android.injected.version.name" => resolved_version_label
      }
    )

    supply(
      track: "alpha",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_JSON_KEY"],
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end

platform :ios do
  desc "Build iOS and upload to App Store Connect"
  lane :ci_ios do
    prepare_build_dirs

    team_id = resolved_ios_team_id
    build_number = resolved_ios_build_number
    version_label = resolved_version_label
    profile_name = resolved_ios_profile_name

    UI.important("iOS team id: #{team_id}")
    UI.important("iOS build number: #{build_number}")
    UI.important("iOS version label: #{version_label}")
    UI.important("iOS provisioning profile: #{profile_name}")

    setup_ci(
      keychain_name: "build.keychain",
      timeout: 21600
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_API_KEY_BASE64"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      app_identifier: "com.arinora.rawarr",
      team_id: team_id,
      api_key: api_key,
      readonly: true,
      keychain_name: "build.keychain"
    )

    increment_version_number(
      version_number: version_label,
      xcodeproj: "ios/Yuzic.xcodeproj"
    )

    increment_build_number(
      build_number: build_number,
      xcodeproj: "ios/Yuzic.xcodeproj"
    )

    build_app(
      scheme: "Yuzic",
      workspace: "ios/Yuzic.xcworkspace",
      export_method: "app-store",
      export_team_id: team_id,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number} MARKETING_VERSION=#{version_label}",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.arinora.rawarr" => profile_name
        }
      },
      output_directory: "build/ios",
      output_name: "Yuzic.ipa",
      include_symbols: false,
      include_bitcode: false
    )

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      run_precheck_before_submit: false
    )
  end
end
