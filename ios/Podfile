require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']

# Prebuilt React Native core (React-Core-prebuilt / ReactNativeDependencies) was compiled
# against an older Xcode SDK and is missing debug-only symbols (Sealable, DebugStringConvertible,
# RCTPackagerConnection, etc.) when linking against newer SDKs. Force source build always.
ENV.delete('RCT_USE_RN_DEP')
ENV.delete('RCT_USE_PREBUILT_RNCORE')
platform :ios, podfile_properties['ios.deploymentTarget'] || '16.0'

prepare_react_native_project!

target 'Yuzic' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # fmt 11.0.2 trips Apple clang's C++20 consteval path in Xcode 26.x.
    # Compile only fmt as C++17; React Native pods remain on their normal C++20 setting.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'fmt'

      target.build_configurations.each do |build_configuration|
        build_configuration.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      end
    end

    # expo-modules-core sets swift_version='6.0' but its source uses @MainActor in protocol
    # conformance position (e.g. "class Foo: @MainActor Protocol"), which is Swift-6-only
    # syntax. Compiling in Swift 5 mode with minimal strict concurrency lets us fix just
    # those three parse errors below without needing a patch file.
    installer.pods_project.targets.each do |target|
      next unless target.name == 'ExpoModulesCore'

      target.build_configurations.each do |build_configuration|
        build_configuration.build_settings['SWIFT_VERSION'] = '5'
        build_configuration.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
      end
    end

    # Remove @MainActor from protocol conformance positions — syntax only valid in Swift 6.
    # Done here so it self-heals after npm ci without needing a patch file.
    expo_ios = File.join(__dir__, '..', 'node_modules', 'expo-modules-core', 'ios')
    [
      ['Core/Views/ViewDefinition.swift',
       'extension UIView: @MainActor AnyArgument',
       'extension UIView: AnyArgument'],
      ['Core/Views/SwiftUI/SwiftUIVirtualView.swift',
       'extension ExpoSwiftUI.SwiftUIVirtualView: @MainActor ExpoSwiftUI.ViewWrapper',
       'extension ExpoSwiftUI.SwiftUIVirtualView: ExpoSwiftUI.ViewWrapper'],
      ['Core/Views/SwiftUI/SwiftUIHostingView.swift',
       'ExpoView, @MainActor AnyExpoSwiftUIHostingView',
       'ExpoView, AnyExpoSwiftUIHostingView'],
    ].each do |rel, from, to|
      path = File.join(expo_ios, rel)
      next unless File.exist?(path)
      src = File.read(path)
      next unless src.include?(from)
      File.write(path, src.gsub(from, to))
    end
  end
end
