{
  "name": "yuzic",
  "main": "expo-router/entry",
  "version": "1.3.7",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "test:e2e": "maestro test .maestro/smoke.yaml && maestro test .maestro/common-user-flows.yaml",
    "test:e2e:smoke": "maestro test .maestro/smoke.yaml",
    "test:e2e:flows": "maestro test .maestro/common-user-flows.yaml",
    "lint": "expo lint"
  },
  "overrides": {
    "lucide-react-native": {
      "react": "^19"
    }
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^expo-modules-core$": "<rootDir>/node_modules/expo-modules-core",
      "^expo-modules-core/(.*)$": "<rootDir>/node_modules/expo-modules-core/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|expo-modules-core|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|immer)/)"
    ]
  },
  "dependencies": {
    "@backpackapp-io/react-native-toast": "^0.13.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-community/slider": "5.1.2",
    "@react-navigation/native": "^7.0.0",
    "@reduxjs/toolkit": "^2.5.0",
    "@rntp/player": "^5.0.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-async-storage-persister": "^5.90.19",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-persist-client": "^5.90.19",
    "expo": "^55.0.23",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-file-system": "~55.0.16",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-splash-screen": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "i18next": "^25.8.4",
    "lucide-react-native": "^0.468.0",
    "md5": "^2.3.0",
    "moti": "^0.30.0",
    "react": "19.2.0",
    "react-airplay": "^1.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.4",
    "react-native": "^0.83.4",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-exception-handler": "^2.10.10",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-cast": "^4.9.1",
    "react-native-image-colors": "^1.5.2",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "0.35.3",
    "react-native-reanimated": "^4.3.0",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-ssdp": "^2.8.2",
    "react-native-svg": "15.15.3",
    "react-native-turbo-image": "1.24.1",
    "react-native-udp": "^4.1.7",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "reanimated-color-picker": "^4.2.0",
    "redux-persist": "^6.0.0",
    "shaka-player": "^4.7.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.14",
    "@types/react-native-keyboard-spacer": "^0.4.6",
    "baseline-browser-mapping": "^2.9.6",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.16",
    "react-native-svg-transformer": "^1.5.1",
    "typescript": "^5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-native-community/netinfo",
        "react-native"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-exception-handler",
          "react-airplay",
          "react-native-restart"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
